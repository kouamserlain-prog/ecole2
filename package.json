{
  "name": "school-manager-app",
  "version": "1.0.0",
  "description": "Application de gestion scolaire complète",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web:wait\"",
    "dev:server": "cd server && npm run dev",
    "dev:web": "cd web && npm run dev",
    "dev:web:wait": "node scripts/wait-for-api.mjs && npm run dev:web",
    "build": "cd server && npm run build && cd ../web && npm run build",
    "install:all": "npm install && cd server && npm install && cd ../web && npm install",
    "prisma:seed": "cd server && npm run prisma:seed",
    "db:seed": "npm run prisma:seed",
    "prisma:generate": "cd server && npm run prisma:generate",
    "prisma:push": "cd server && npm run prisma:push",
    "test": "cd server && npm run test:all && cd ../web && npm run test:exports",
    "test:unit": "cd server && npm run test",
    "test:exports": "cd server && npm run test:import-export"
  },
  "keywords": ["school", "management", "education"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "next": "16.2.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

