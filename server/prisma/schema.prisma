/// Demande d'inscription / pré-admission (dossier candidat)
model Admission {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  reference        String          @unique
  status           AdmissionStatus @default(PENDING)
  schoolId         String?         @db.ObjectId

  firstName        String
  lastName         String
  /// Matricule déclaré par la famille (établissement précédent ou national), si connu
  matricule        String?
  email            String
  phone            String?
  dateOfBirth      DateTime
  gender           Gender

  desiredLevel     String
  academicYear     String
  previousSchool   String?

  parentName       String?
  parentPhone      String?
  parentEmail      String?
  address          String?

  motivation       String?
  adminNotes       String?

  /// Moyennes (2nde, 1ère, Terminale) — formulaire d'inscription en ligne
  gradeTerm1                 Float?
  gradeTerm2                 Float?
  gradeAnnualGeneral         Float?
  gradeAnnualSpecific        Float?
  gradeAnnualLiterary        Float?

  /// Bulletin du 3e trimestre (PDF / image) — inscription en ligne lycée
  term3ReportCardUrl         String?
  term3ReportCardOriginalName String?
  term3ReportCardMimeType    String?

  proposedClassId  String?   @db.ObjectId
  proposedClass    Class?    @relation(fields: [proposedClassId], references: [id])
  school           School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  enrolledStudentId String?  @db.ObjectId

  reviewedById     String?   @db.ObjectId
  reviewedAt       DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([academicYear])
  @@index([email])
  @@index([matricule])
  @@index([schoolId])
  @@index([schoolId, status])
  @@index([enrolledStudentId])
  @@map("admissions")
}

/// Établissement scolaire (collège / lycée) — périmètre multi-sites
model School {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  slug            String   @unique
  shortName       String?
  address         String?
  phone           String?
  email           String?
  website         String?
  principalName   String?
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members         SchoolMember[]
  classes         Class[]
  students        Student[]
  admissions      Admission[]
  staffMembers    StaffMember[]
  staffMetiers    SchoolStaffMetier[]
  workspaces      AdminWorkspace[]
  branding        AppBranding?

  @@index([isActive])
  @@index([isDefault])
  @@map("schools")
}

/// Métier du personnel de soutien (STAFF) configuré par établissement — les admins restent globaux (AdminWorkspace).
model SchoolStaffMetier {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String           @db.ObjectId
  supportKind    SupportStaffKind
  /// Libellé affiché (sinon libellé plateforme par défaut)
  label          String?
  description    String?
  /// Modules par défaut pour ce métier dans cet établissement
  defaultModules String[]         @default([])
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, supportKind])
  @@index([schoolId, isActive])
  @@map("school_staff_metiers")
}

/// Accès d’un utilisateur à un ou plusieurs établissements
model SchoolMember {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  userId      String   @db.ObjectId
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId])
  @@index([userId])
  @@index([userId, isDefault])
  @@map("school_members")
}

model IdentityDocument {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  studentId    String               @db.ObjectId
  type         IdentityDocumentType
  label        String?
  fileUrl      String
  originalName String
  mimeType     String?
  fileSize     Int?
  notes        String?
  uploadedById String               @db.ObjectId
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("IdentityDocUploader", fields: [uploadedById], references: [id])

  @@index([studentId])
  @@map("identity_documents")
}

model StudentSchoolHistory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String   @db.ObjectId
  academicYear   String
  className      String?
  classLevel     String?
  classId        String?  @db.ObjectId
  establishment  String?
  notes          String?
  createdAt      DateTime @default(now())

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_school_history")
}

model StudentTransfer {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  studentId       String              @db.ObjectId
  fromClassId     String?             @db.ObjectId
  toClassId       String?             @db.ObjectId
  effectiveDate   DateTime
  transferType    StudentTransferType @default(CLASS_CHANGE)
  reason          String?
  notes           String?
  createdById     String?             @db.ObjectId
  createdAt       DateTime            @default(now())

  student         Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_transfers")
}

/// Espace d'administration : périmètre de modules / fonctionnalités assignables aux administrateurs.
model AdminWorkspace {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String   @unique
  description    String?
  enabledModules String[]
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  schoolId       String?  @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school  School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  members AdminWorkspaceMember[]

  @@index([isActive])
  @@index([schoolId])
  @@map("admin_workspaces")
}

model AdminWorkspaceMember {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  userId      String   @db.ObjectId
  createdAt   DateTime @default(now())

  workspace AdminWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("admin_workspace_members")
}

/// Identité visuelle par établissement (id = schoolId ou "default" pour rétrocompatibilité).
model AppBranding {
  id                String   @id @map("_id")
  schoolId          String?  @unique @db.ObjectId
  navigationLogoUrl String?
  loginLogoUrl      String?
  faviconUrl        String?
  appTitle          String?
  appTagline        String?
  /// Fiche établissement (onglet Paramètres → Établissement)
  schoolDisplayName String?
  schoolAddress     String?
  schoolPhone       String?
  schoolEmail       String?
  schoolWebsite     String?
  schoolPrincipal   String?
  /// Portrait affiché sur la page d’accueil (section « Mot de la Directrice des Études »)
  studiesDirectorPhotoUrl String?
  /// Images personnalisables de la page d’accueil (clés homeHeroPlatform, homePillarPedagogy, …)
  homePageImages        Json?
  updatedAt         DateTime @updatedAt

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("app_branding")
}

/// Cible d'une demande de modification (note ou moyenne bulletin)
enum AcademicChangeTarget {
  GRADE
  REPORT_CARD
}

enum AcademicChangeKind {
  CREATE
  UPDATE
  DELETE
}

/// Circuit de validation : prof principal → éducateur → directeur des études
enum AcademicChangeWorkflowStatus {
  PENDING_MAIN_TEACHER
  PENDING_EDUCATOR
  PENDING_STUDIES_DIRECTOR
  APPROVED
  REJECTED
}

model AcademicChangeRequest {
  id              String                       @id @default(auto()) @map("_id") @db.ObjectId
  target          AcademicChangeTarget
  kind            AcademicChangeKind
  status          AcademicChangeWorkflowStatus @default(PENDING_MAIN_TEACHER)

  studentId       String                       @db.ObjectId
  classId         String?                      @db.ObjectId
  gradeId         String?                      @db.ObjectId
  reportCardId    String?                      @db.ObjectId

  payload         Json
  previousPayload Json?

  requestedByUserId String                     @db.ObjectId
  requestedAt     DateTime                     @default(now())

  mainTeacherApprovedAt         DateTime?
  mainTeacherApprovedByUserId   String?                      @db.ObjectId
  mainTeacherNote               String?

  educatorApprovedAt            DateTime?
  educatorApprovedByUserId      String?                      @db.ObjectId
  educatorNote                  String?

  studiesDirectorApprovedAt     DateTime?
  studiesDirectorApprovedByUserId String?                    @db.ObjectId
  studiesDirectorNote           String?

  rejectedAt       DateTime?
  rejectedByUserId String?                      @db.ObjectId
  rejectionReason  String?

  appliedAt        DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([status])
  @@index([studentId])
  @@index([classId])
  @@index([gradeId])
  @@map("academic_change_requests")
}

// ——— E-learning & ressources numériques (§10) ———

enum ElearningLessonKind {
  VIDEO
  DOCUMENT
  EXERCISE
  QUIZ
  EXTERNAL_LINK
  HOMEWORK
}

enum ElearningQuestionKind {
  MCQ
  TRUE_FALSE
  SHORT_TEXT
}

enum VirtualClassSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum PedagogicalResourceKind {
  DOCUMENT
  VIDEO
  AUDIO
  IMAGE
  EXTERNAL_LINK
  MULTIMEDIA
}

/// Parcours e-learning (cours en ligne)
model ElearningCourse {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  subject     String?
  level       String?
  coverImageUrl String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacherId   String   @db.ObjectId
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  classId     String?  @db.ObjectId
  class       Class?   @relation(fields: [classId], references: [id])
  courseId    String?  @db.ObjectId
  course      Course?  @relation(fields: [courseId], references: [id])

  lessons     ElearningLesson[]
  virtualSessions VirtualClassSession[]

  @@index([teacherId])
  @@index([classId])
  @@index([isPublished])
  @@map("elearning_courses")
}

/// Leçon / activité dans un parcours (vidéo, doc, quiz, devoir…)
model ElearningLesson {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  elearningCourseId String            @db.ObjectId
  elearningCourse ElearningCourse     @relation(fields: [elearningCourseId], references: [id], onDelete: Cascade)
  title           String
  kind            ElearningLessonKind
  sortOrder       Int                 @default(0)
  fileUrl         String?
  externalUrl     String?
  body            String?
  durationMinutes Int?
  isPublished     Boolean             @default(true)
  assignmentId    String?             @db.ObjectId
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  quiz            ElearningQuiz?
  progress        ElearningLessonProgress[]

  @@index([elearningCourseId])
  @@map("elearning_lessons")
}

model ElearningQuiz {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  lessonId     String   @unique @db.ObjectId
  lesson       ElearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title        String
  passingScore Float    @default(50)
  autoGrade    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questions    ElearningQuizQuestion[]
  attempts     ElearningQuizAttempt[]

  @@map("elearning_quizzes")
}

model ElearningQuizQuestion {
  id            String                @id @default(auto()) @map("_id") @db.ObjectId
  quizId        String                @db.ObjectId
  quiz          ElearningQuiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  kind          ElearningQuestionKind
  prompt        String
  options       Json?
  correctAnswer String
  points        Int                   @default(1)
  sortOrder     Int                   @default(0)

  @@index([quizId])
  @@map("elearning_quiz_questions")
}

model ElearningQuizAttempt {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  quizId      String   @db.ObjectId
  quiz        ElearningQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String   @db.ObjectId
  student     Student  @relation(fields: [studentId], references: [id])
  answers     Json
  score       Float?
  maxScore    Float?
  passed      Boolean?
  submittedAt DateTime @default(now())

  @@index([quizId])
  @@index([studentId])
  @@map("elearning_quiz_attempts")
}

model ElearningLessonProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  lessonId    String   @db.ObjectId
  lesson      ElearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  studentId   String   @db.ObjectId
  student     Student  @relation(fields: [studentId], references: [id])
  completedAt DateTime @default(now())

  @@unique([lessonId, studentId])
  @@map("elearning_lesson_progress")
}

/// Banque de ressources pédagogiques partagées (§10.3)
model PedagogicalResourceBank {
  id                  String                  @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  description         String?
  kind                PedagogicalResourceKind
  subject             String?
  level               String?
  fileUrl             String?
  externalUrl         String?
  tags                String[]
  sharedWithTeachers  Boolean                 @default(true)
  createdByTeacherId  String                  @db.ObjectId
  teacher             Teacher                 @relation(fields: [createdByTeacherId], references: [id])
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([subject])
  @@index([level])
  @@index([createdByTeacherId])
  @@map("pedagogical_resource_bank")
}

/// Classe virtuelle (visio, tableau blanc, enregistrement — liens externes en v1)
model VirtualClassSession {
  id                  String                    @id @default(auto()) @map("_id") @db.ObjectId
  title               String
  description         String?
  scheduledStart      DateTime
  durationMinutes     Int                       @default(60)
  status              VirtualClassSessionStatus @default(SCHEDULED)
  meetingUrl          String?
  recordingUrl        String?
  whiteboardUrl       String?
  screenShareEnabled  Boolean                   @default(true)
  chatEnabled         Boolean                   @default(true)
  breakoutRoomsNotes  String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  teacherId           String                    @db.ObjectId
  teacher             Teacher                   @relation(fields: [teacherId], references: [id])
  elearningCourseId   String?                   @db.ObjectId
  elearningCourse     ElearningCourse?          @relation(fields: [elearningCourseId], references: [id])
  courseId            String?                   @db.ObjectId
  course              Course?                   @relation(fields: [courseId], references: [id])
  classId             String?                   @db.ObjectId
  class               Class?                    @relation(fields: [classId], references: [id])

  @@index([teacherId])
  @@index([scheduledStart])
  @@index([status])
  @@map("virtual_class_sessions")
}

