// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// seed {
//   provider = "tsx"
//   path     = "./seed.ts"
// }

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
  EDUCATOR
  STAFF
}

/// Personnel non-enseignant : administration, soutien (bibliothèque, infirmerie…), sécurité
enum StaffCategory {
  ADMINISTRATION
  SUPPORT
  SECURITY
}

/// Sous-type utile lorsque staffCategory = SUPPORT
enum SupportStaffKind {
  LIBRARIAN
  NURSE
  SECRETARY
  ACCOUNTANT
  IT
  MAINTENANCE
  /// Directeur(trice) des études — suivi pédagogique, examens, orientation
  STUDIES_DIRECTOR
  /// Économe — gestion financière de l’établissement (trésorerie scolaire)
  BURSAR
  OTHER
}

enum ParentInteractionChannel {
  PHONE
  EMAIL
  SMS
  MEETING
  PORTAL_MESSAGE
  WHATSAPP
  OTHER
}

enum ParentConsentType {
  IMAGE_PUBLICATION
  SCHOOL_TRIP
  MEDICAL_EMERGENCY
  DATA_PROCESSING
  COMMUNICATION_CHANNELS
  AUTHORIZED_PICKUP_POLICY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AbsenceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum EvaluationType {
  EXAM
  EVALUATION
  HOME_EXERCISE
  LEVEL_HOMEWORK
  CLASS_HOMEWORK
  ORAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  CASH
}

/// Type de frais scolaire (barème / ligne élève)
enum SchoolFeeType {
  ENROLLMENT
  TUITION
  CANTEEN
  TRANSPORT
  ACTIVITY
  MATERIAL
  OTHER
}

/// Rythme de facturation théorique (ligne catalogue ou aide à la génération)
enum TuitionBillingPeriod {
  ONE_TIME
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

/// Portée d’un poste du catalogue de frais
enum TuitionFeeCatalogScope {
  ALL_STUDENTS
  BY_LEVEL
  BY_CLASS
}

enum AdmissionStatus {
  PENDING
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WAITLIST
  ENROLLED
}

enum IdentityDocumentType {
  NATIONAL_ID
  BIRTH_CERTIFICATE
  PASSPORT
  RESIDENCE_PERMIT
  PHOTO_ID
  OTHER
}

/// Documents RH / contrats (dossier enseignant)
enum TeacherAdminDocumentType {
  CONTRACT
  DIPLOMA_COPY
  HR_LETTER
  CERTIFICATE
  OTHER
}

// Statut d'inscription scolaire (indépendant du compte utilisateur)
enum EnrollmentStatus {
  ACTIVE
  SUSPENDED
  GRADUATED
  ARCHIVED
}

/// Changement de classe, réinscription, mutation ou départ
enum StudentTransferType {
  CLASS_CHANGE
  REENROLLMENT
  MUTATION
  DEPARTURE
}

enum TeacherLeaveType {
  ANNUAL
  SICK
  PERSONAL
  TRAINING
  OTHER
}

enum TeacherLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Statut d'engagement pédagogique de l'enseignant
enum TeacherEngagementKind {
  PERMANENT
  VACATAIRE
}

enum CalendarEventType {
  HOLIDAY       // Jour férié
  VACATION      // Vacances scolaires
  EXAM_PERIOD   // Période d'examens
  MEETING       // Réunion / événement
  OTHER
}

enum ParentTeacherAppointmentStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  COMPLETED
}

enum ParentTeacherAppointmentCancelledBy {
  PARENT
  TEACHER
  ADMIN
}

enum DisciplinaryRecordCategory {
  VERBAL_WARNING
  WRITTEN_WARNING
  REPRIMAND
  TEMPORARY_EXCLUSION
  DISCIPLINE_COUNCIL_HEARING
  DISCIPLINE_COUNCIL_DECISION
  BEHAVIOR_CONTRACT
  OTHER
}

enum BehaviorContractStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ExtracurricularCategory {
  CLUB_ASSOCIATION
  SPORT_COMPETITION
  ARTS_CULTURE
  EDUCATIONAL_OUTING
  SCHOOL_TRIP
  OTHER
}

enum ExtracurricularOfferingKind {
  CLUB
  EVENT
}

enum ExtracurricularRegistrationStatus {
  PENDING
  CONFIRMED
  WAITLIST
  CANCELLED
}

/// Public cible pour les conseils d’orientation (portail).
enum OrientationAdviceAudience {
  ALL
  PARENT
  STUDENT
}

enum OrientationPartnershipKind {
  UNIVERSITY
  COMPANY
  OTHER
}

enum OrientationPlacementKind {
  INTERNSHIP_SCHOOL
  INTERNSHIP_COMPANY
  APPRENTICESHIP
}

enum OrientationPlacementStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrientationFollowUpStatus {
  PLANNED
  IN_PROGRESS
  DONE
  ARCHIVED
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  role      Role
  firstName String
  lastName  String
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  teacherProfile Teacher?
  studentProfile Student?
  parentProfile  Parent?
  educatorProfile Educator?
  staffProfile   StaffMember?
  sentMessages   Message[]     @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
  announcements  Announcement[]
  notifications  Notification[]
  loginLogs      LoginLog[]
  evaluatedConducts Conduct[]
  securityEvents SecurityEvent[]
  payments       Payment[]
  schoolExpensesRecorded SchoolExpense[] @relation("SchoolExpenseRecorder")
  pettyCashMovementsRecorded PettyCashMovement[] @relation("PettyCashRecorder")
  uploadedIdentityDocuments IdentityDocument[] @relation("IdentityDocUploader")
  libraryBorrowedLoans     LibraryLoan[]      @relation("LibraryBorrower")
  libraryCreatedLoans       LibraryLoan[]      @relation("LibraryLoanCreator")
  libraryReservations     LibraryReservation[] @relation("LibraryReserver")
  libraryPenalties        LibraryPenalty[]     @relation("LibraryPenaltyUser")
  digitalLibraryCreated   DigitalLibraryResource[]    @relation("DigitalLibraryCreator")
  digitalLibraryDownloads DigitalLibraryDownloadGrant[] @relation("DigitalLibraryDownloadUser")
  materialMaintReported   MaterialMaintenance[] @relation("MatMaintReporter")
  materialMaintAssigned     MaterialMaintenance[] @relation("MatMaintAssignee")
  materialRoomReservationsRequested MaterialRoomReservation[] @relation("MatRoomReservationRequester")
  uploadedTeacherAdminDocuments TeacherAdministrativeDocument[] @relation("TeacherAdminDocUploader")
  disciplinaryRulebooksAuthored SchoolDisciplinaryRulebook[] @relation("DisciplinaryRulebookAuthor")
  disciplinaryRecordsRecorded StudentDisciplinaryRecord[] @relation("DisciplinaryRecordRecorder")
  extracurricularOfferingsCreated ExtracurricularOffering[] @relation("ExtracurricularOfferingAuthor")
  orientationFollowUpsAsCounselor StudentOrientationFollowUp[] @relation("OrientationFollowUpCounselor")
  orientationFollowUpsCreated     StudentOrientationFollowUp[] @relation("OrientationFollowUpCreatedBy")
  orientationPlacementsCreated    StudentOrientationPlacement[]  @relation("OrientationPlacementCreatedBy")
  twoFactorSettings               UserTwoFactorSettings?
  adminWorkspaceMemberships         AdminWorkspaceMember[]
  schoolMemberships               SchoolMember[]

  @@map("users")
}

model UserTwoFactorSettings {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @unique @db.ObjectId
  enabled           Boolean  @default(false)
  method            String   @default("TOTP")
  secretEncrypted   String
  backupCodesHash   String?
  lastVerifiedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_two_factor_settings")
}

enum LibraryLoanStatus {
  ACTIVE
  RETURNED
}

enum LibraryReservationStatus {
  PENDING
  READY
  FULFILLED
  CANCELLED
  EXPIRED
}

/// Type de ressource — bibliothèque numérique
enum DigitalLibraryResourceKind {
  EBOOK
  PDF
  PEDAGOGICAL
}

model DigitalLibraryResource {
  id                    String                   @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  author                String?
  description           String?
  kind                  DigitalLibraryResourceKind
  fileUrl               String
  fileName              String?
  mimeType              String?
  fileSizeBytes         Int?
  coverImageUrl         String?
  subject               String?
  level                 String?
  onlineAccessEnabled   Boolean                  @default(true)
  tempDownloadEnabled   Boolean                  @default(true)
  downloadTtlHours      Int                      @default(48)
  /// Rôles autorisés (vide = tous les comptes authentifiés éligibles)
  allowedRoles          String[]                 @default([])
  isActive              Boolean                  @default(true)
  publishedAt           DateTime?
  createdById           String?                  @db.ObjectId
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  createdBy      User?                         @relation("DigitalLibraryCreator", fields: [createdById], references: [id])
  downloadGrants DigitalLibraryDownloadGrant[]

  @@index([kind])
  @@index([isActive])
  @@index([title])
  @@map("digital_library_resources")
}

model DigitalLibraryDownloadGrant {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  resourceId   String   @db.ObjectId
  userId       String   @db.ObjectId
  token        String   @unique
  expiresAt    DateTime
  downloadedAt DateTime?
  createdAt    DateTime @default(now())

  resource DigitalLibraryResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user     User                   @relation("DigitalLibraryDownloadUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([resourceId])
  @@index([userId])
  @@index([expiresAt])
  @@map("digital_library_download_grants")
}

model LibraryBook {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  isbn             String?
  title            String
  author           String
  publisher        String?
  publicationYear  Int?
  category         String?
  description      String?
  copiesTotal      Int      @default(1)
  copiesAvailable  Int      @default(1)
  shelfLocation    String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  loans         LibraryLoan[]
  reservations  LibraryReservation[]

  @@index([title])
  @@index([isbn])
  @@map("library_books")
}

model LibraryLoan {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  bookId      String            @db.ObjectId
  borrowerId  String            @db.ObjectId
  status      LibraryLoanStatus @default(ACTIVE)
  loanedAt    DateTime          @default(now())
  dueDate     DateTime
  returnedAt  DateTime?
  notes       String?
  createdById String?           @db.ObjectId

  book       LibraryBook @relation(fields: [bookId], references: [id])
  borrower   User        @relation("LibraryBorrower", fields: [borrowerId], references: [id])
  createdBy  User?       @relation("LibraryLoanCreator", fields: [createdById], references: [id])
  penalties  LibraryPenalty[]

  @@index([bookId])
  @@index([borrowerId])
  @@index([status])
  @@map("library_loans")
}

model LibraryReservation {
  id          String                   @id @default(auto()) @map("_id") @db.ObjectId
  bookId      String                   @db.ObjectId
  userId      String                   @db.ObjectId
  status      LibraryReservationStatus @default(PENDING)
  reservedAt  DateTime                 @default(now())
  expiresAt   DateTime?
  fulfilledAt DateTime?

  book LibraryBook @relation(fields: [bookId], references: [id])
  user User        @relation("LibraryReserver", fields: [userId], references: [id])

  @@index([bookId])
  @@index([userId])
  @@index([status])
  @@map("library_reservations")
}

model LibraryPenalty {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  loanId    String?  @db.ObjectId
  userId    String   @db.ObjectId
  amount    Float
  reason    String
  paid      Boolean  @default(false)
  paidAt    DateTime?
  waived    Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())

  loan LibraryLoan? @relation(fields: [loanId], references: [id])
  user User         @relation("LibraryPenaltyUser", fields: [userId], references: [id])

  @@index([userId])
  @@map("library_penalties")
}

// ——— Gestion matérielle (équipements, salles, maintenance, allocations) ———

enum MaterialEquipmentCondition {
  GOOD
  FAIR
  NEEDS_REPAIR
  OUT_OF_SERVICE
}

enum MaterialMaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum MaterialAllocationTarget {
  USER
  CLASS
  ROOM
}

enum MaterialAllocationStatus {
  ACTIVE
  RETURNED
  CANCELLED
}

enum MaterialStockItemType {
  SCHOOL_SUPPLY
  CLEANING_PRODUCT
  SAFETY_STOCK
  OTHER
}

enum MaterialStockMovementType {
  IN
  OUT
  ADJUSTMENT
  INVENTORY_COUNT
}

enum MaterialStockOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum MaterialRoomReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model MaterialRoom {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String?
  building    String?
  floor       String?
  capacity    Int?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipmentStored MaterialEquipment[]
  maintenance     MaterialMaintenance[]
  reservations    MaterialRoomReservation[]

  @@index([name])
  @@map("material_rooms")
}

model MaterialRoomReservation {
  id                String                        @id @default(auto()) @map("_id") @db.ObjectId
  roomId            String                        @db.ObjectId
  title             String
  startAt           DateTime
  endAt             DateTime
  status            MaterialRoomReservationStatus @default(CONFIRMED)
  requesterName     String?
  requesterUserId   String?                       @db.ObjectId
  notes             String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  room              MaterialRoom                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  requesterUser     User?                         @relation("MatRoomReservationRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)

  @@index([roomId, startAt])
  @@map("material_room_reservations")
}

model MaterialEquipment {
  id            String                     @id @default(auto()) @map("_id") @db.ObjectId
  roomId        String?                    @db.ObjectId
  name          String
  category      String
  serialNumber  String?
  quantity      Int                        @default(1)
  condition     MaterialEquipmentCondition @default(GOOD)
  notes         String?
  purchasedAt   DateTime?
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  room          MaterialRoom?        @relation(fields: [roomId], references: [id])
  maintenance   MaterialMaintenance[]
  allocations   MaterialAllocation[]

  @@index([category])
  @@index([name])
  @@map("material_equipment")
}

model MaterialMaintenance {
  id            String                   @id @default(auto()) @map("_id") @db.ObjectId
  equipmentId   String?                  @db.ObjectId
  roomId        String?                  @db.ObjectId
  title         String
  description   String?
  status        MaterialMaintenanceStatus @default(OPEN)
  priority      String                   @default("normal")
  costEstimate  Float?
  costActual    Float?
  openedAt      DateTime                 @default(now())
  closedAt      DateTime?
  reportedById  String?                  @db.ObjectId
  assigneeId    String?                  @db.ObjectId

  equipment     MaterialEquipment? @relation(fields: [equipmentId], references: [id])
  room          MaterialRoom?      @relation(fields: [roomId], references: [id])
  reportedBy    User?              @relation("MatMaintReporter", fields: [reportedById], references: [id])
  assignee      User?              @relation("MatMaintAssignee", fields: [assigneeId], references: [id])

  @@index([status])
  @@map("material_maintenance")
}

model MaterialAllocation {
  id          String                   @id @default(auto()) @map("_id") @db.ObjectId
  equipmentId String                   @db.ObjectId
  targetType  MaterialAllocationTarget
  targetId    String
  quantity    Int                      @default(1)
  startDate   DateTime                 @default(now())
  endDate     DateTime?
  status      MaterialAllocationStatus @default(ACTIVE)
  purpose     String?
  notes       String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  equipment   MaterialEquipment @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId])
  @@index([status])
  @@map("material_allocations")
}

model MaterialStockItem {
  id            String                @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  category      String?
  type          MaterialStockItemType @default(OTHER)
  unit          String                @default("unité")
  currentQty    Float                 @default(0)
  safetyQty     Float                 @default(0)
  reorderQty    Float?
  location      String?
  notes         String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  movements     MaterialStockMovement[]
  orderLines    MaterialStockOrderLine[]

  @@index([type])
  @@index([name])
  @@map("material_stock_items")
}

model MaterialStockMovement {
  id            String                    @id @default(auto()) @map("_id") @db.ObjectId
  itemId        String                    @db.ObjectId
  type          MaterialStockMovementType
  quantity      Float
  unitCost      Float?
  totalCost     Float?
  note          String?
  reference     String?
  occurredAt    DateTime                  @default(now())
  createdAt     DateTime                  @default(now())

  item          MaterialStockItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, occurredAt])
  @@index([type])
  @@map("material_stock_movements")
}

model MaterialStockOrder {
  id            String                   @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber   String                   @unique
  supplierName  String
  status        MaterialStockOrderStatus @default(DRAFT)
  orderedAt     DateTime?
  expectedAt    DateTime?
  receivedAt    DateTime?
  notes         String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  lines         MaterialStockOrderLine[]

  @@index([status, createdAt])
  @@map("material_stock_orders")
}

model MaterialStockOrderLine {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String             @db.ObjectId
  itemId        String             @db.ObjectId
  qtyOrdered    Float
  qtyReceived   Float              @default(0)
  unitCost      Float?
  notes         String?

  order         MaterialStockOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item          MaterialStockItem  @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([itemId])
  @@map("material_stock_order_lines")
}

model Teacher {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  employeeId    String   @unique
  nfcId         String?
  biometricId   String?
  /// Descripteur face-api (128 floats) pour reconnaissance faciale au pointage
  faceDescriptor Json?
  faceEnrolledAt DateTime?
  specialization String
  hireDate      DateTime
  contractType  String
  /// Permanent (titulaire) ou vacataire
  engagementKind TeacherEngagementKind @default(PERMANENT)
  salary        Float?
  /// Présentation / compétences (profil)
  bio           String?
  /// Plafond horaire contractuel (h/semaine), distinct du volume issu des cours
  maxWeeklyHours Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
  classes       Class[]
  courses       Course[]
  absences      Absence[]
  grades        Grade[]
  assignments   Assignment[]
  leaves        TeacherLeave[]
  performanceReviews TeacherPerformanceReview[]
  attendances   TeacherAttendance[]
  parentTeacherAppointments ParentTeacherAppointment[]
  scheduleAvailabilitySlots TeacherScheduleAvailabilitySlot[]
  substituteSchedules Schedule[] @relation("ScheduleSubstitute")
  qualifications            TeacherQualification[]
  careerHistory             TeacherCareerHistory[]
  professionalTrainings     TeacherProfessionalTraining[]
  administrativeDocuments   TeacherAdministrativeDocument[]
  elearningCourses          ElearningCourse[]
  pedagogicalResources      PedagogicalResourceBank[]
  virtualClassSessions      VirtualClassSession[]

  @@index([nfcId])
  @@index([biometricId])
  @@index([engagementKind])
  @@map("teachers")
}

model TeacherQualification {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  teacherId    String    @db.ObjectId
  title        String
  institution  String?
  field        String?
  obtainedAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  teacher      Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@map("teacher_qualifications")
}

model TeacherCareerHistory {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  teacherId    String    @db.ObjectId
  institution  String
  role         String
  startDate    DateTime
  endDate      DateTime?
  country      String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  teacher      Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@map("teacher_career_history")
}

model TeacherProfessionalTraining {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  teacherId    String    @db.ObjectId
  title        String
  organization String?
  hours        Float?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  teacher      Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@map("teacher_professional_trainings")
}

model TeacherAdministrativeDocument {
  id           String                  @id @default(auto()) @map("_id") @db.ObjectId
  teacherId    String                  @db.ObjectId
  type         TeacherAdminDocumentType
  label        String?
  fileUrl      String
  originalName String
  mimeType     String?
  fileSize     Int?
  notes        String?
  uploadedById String                  @db.ObjectId
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  teacher      Teacher                 @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  uploadedBy   User                    @relation("TeacherAdminDocUploader", fields: [uploadedById], references: [id])

  @@index([teacherId])
  @@map("teacher_administrative_documents")
}

model TeacherScheduleAvailabilitySlot {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teacherId String   @db.ObjectId
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String
  endTime   String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId, dayOfWeek])
  @@map("teacher_schedule_availability_slots")
}

model RoomScheduleUnavailableSlot {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  roomKey   String
  dayOfWeek Int
  startTime String
  endTime   String
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomKey, dayOfWeek])
  @@map("room_schedule_unavailable_slots")
}

model TeacherLeave {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  teacherId    String             @db.ObjectId
  teacher      Teacher            @relation(fields: [teacherId], references: [id])
  type         TeacherLeaveType
  status       TeacherLeaveStatus @default(PENDING)
  startDate    DateTime
  endDate      DateTime
  reason       String?
  adminComment String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("teacher_leaves")
}

model TeacherPerformanceReview {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  teacherId    String   @db.ObjectId
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  periodLabel  String
  academicYear String
  overallScore Float?
  objectives   String?
  achievements String?
  improvements String?
  reviewerName String?
  createdAt    DateTime @default(now())

