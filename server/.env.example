# Copier vers `.env` et renseigner les valeurs réelles.

# MongoDB (local ou Atlas)
DATABASE_URL="mongodb://localhost:27017/school_manager"

# JWT — obligatoire en production (chaîne assez longue, sans guillemets parasites)
JWT_SECRET=changez-moi-par-une-longue-chaine-aleatoire
JWT_EXPIRES_IN=7d

# Chiffrement AES-256-GCM des champs élève sensibles en base (adresse, contact urgence, infos médicales).
# En production, définir une valeur secrète stable ; sans clé, les valeurs sont conservées en clair (compatible dev).
# SENSITIVE_FIELD_ENCRYPTION_KEY=

PORT=5000
NODE_ENV=development

# Inscription publique (/auth/register).
# En production, elle est désactivée par défaut ; mettre true uniquement si l’école accepte
# la création libre de comptes élève/parent hors workflow d’admission.
# PUBLIC_ACCOUNT_REGISTRATION_ENABLED=false

# Vercel Blob — persistance des images / fichiers uploadés en production (Storage → Blob dans le projet Vercel).
# Injecté automatiquement sur Vercel quand un store Blob est lié. En local, optionnel pour tester le même flux :
# BLOB_READ_WRITE_TOKEN=

# Logs Prisma : ajouter query en dev uniquement si besoin de déboguer (sinon console saturée)
# PRISMA_LOG_QUERIES=true

# Derrière un reverse proxy (Vercel, nginx) pour le rate limiting par IP client
# TRUST_PROXY=1

# Origines autorisées pour CORS (Next.js) — le premier hôte sert aussi aux liens e-mail.
# Si le front et l’API sont derrière le même domaine HTTPS, incluez ce domaine (ex. https://ecole.example.org).
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# E-mail transactionnel (réinitialisation mot de passe, messages) — optionnel
# SMTP_SECURE=true pour le port 465
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# RGPD — réception des demandes d’effacement / limitation (sinon utilise EMAIL_FROM)
# GDPR_CONTACT_EMAIL=privacy@votre-etablissement.fr

# Web Push (notifications navigateur) — générer avec : npx web-push generate-vapid-keys
# VAPID_SUBJECT : mailto: ou URL https du site (bonne pratique RFC)
# VAPID_PUBLIC_KEY copiable côté client via GET /api/push/vapid-public (pas besoin de NEXT_PUBLIC_*)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com

# SMS via Twilio — optionnel (numéros au format E.164, ex. +33612345678)


# Notifications automatiques aux parents lors du pointage (présence / absence)
# NOTIFY_PARENTS_ON_ATTENDANCE=false pour désactiver
# SCHOOL_NAME="Nom de l'établissement"

# Pointage NFC / reconnaissance faciale (terminaux) — obligatoire en production (≥ 32 caractères, unique)
# Ne jamais exposer dans l’URL (?apiKey) : utiliser l’en-tête X-NFC-API-Key uniquement.
# NFC_API_KEY=

# --- Sauvegardes MongoDB (mongodump, MongoDB Database Tools sur le PATH) ---
# Manuel : npm run backup:mongodb (depuis server/)
# Atlas : activer aussi les sauvegardes cloud dans le tableau de bord du cluster.
# ENABLE_SCHEDULED_MONGODB_BACKUPS=true — lance une sauvegarde selon le cron (processus API ; 1 seul worker en prod)
# MONGODB_BACKUP_CRON=0 3 * * * — défaut : tous les jours à 03:00
# MONGODB_BACKUP_DIR=backups/mongodb — dossier relatif au cwd ou chemin absolu
# MONGODB_BACKUP_RETENTION_DAYS=14 — suppression des archives plus anciennes après chaque sauvegarde

# --- Relances automatiques frais de scolarité (notifications + e-mail si SMTP OK) ---
# ENABLE_SCHEDULED_TUITION_REMINDERS=true — désactivé par défaut ; 1 seul worker API en prod
# TUITION_REMINDERS_CRON=0 8 * * * — défaut : chaque jour à 08:00
# TUITION_REMINDER_MIN_INTERVAL_DAYS=7 — pas plus d’une relance auto par ligne de frais sur cette fenêtre
# SMS en plus pour les échéances déjà dépassées (parents avec notifySms=true et numéro valide, Twilio requis)
# TUITION_REMINDER_SMS_OVERDUE=false

# --- Rendez-vous parents-enseignants ---
# APPOINTMENTS_AUTO_CONFIRM=true — crée directement en CONFIRMED (sinon PENDING, validation enseignant)
# ENABLE_SCHEDULED_APPOINTMENT_REMINDERS=true — rappels ~24h et ~1h avant (désactivé par défaut ; 1 worker API en prod)
# APPOINTMENT_REMINDERS_CRON=*/15 * * * * — défaut : toutes les 15 minutes

# Annonce publiée en priorité « urgente » : SMS aux parents (en plus in-app / e-mail / push) si Twilio OK
# ANNOUNCEMENT_URGENT_SMS=false
